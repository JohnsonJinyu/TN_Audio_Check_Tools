<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TN_Audio_Check_Tools"
        x:Class="TN_Audio_Check_Tools.MainWindow"
        mc:Ignorable="d"
        Title="TN_AUDIO_CHECK_TOOLS" Height="700" Width="900">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Left: content display area for check steps and status -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <GroupBox Header="检查步骤" Grid.Row="0">
                    <ScrollViewer Margin="4">
                        <TextBlock x:Name="CheckStepsText" TextWrapping="Wrap">
                            1. 将测试报告文件添加到“测试报告文件列表”。\n
                            2. 选择汇总表模板文件。\n
                            3. 点击 Process 开始校验与汇总。\n
                        </TextBlock>
                    </ScrollViewer>
                </GroupBox>

                <StatusBar Grid.Row="1" Margin="0,6,0,0">
                    <StatusBarItem Width="200">
                        <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Height="16" Width="180" />
                    </StatusBarItem>
                    <StatusBarItem>
                        <TextBlock x:Name="StatusText" Text="就绪" />
                    </StatusBarItem>
                </StatusBar>
            </Grid>

            <!-- spacer -->
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Right: top = 测试报告文件列表, bottom = 汇总表模板 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="140" />
                </Grid.RowDefinitions>

                <!-- 测试报告文件列表 (moved to top of right column) -->
                <GroupBox Header="测试报告文件列表" Grid.Row="0">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="4">
                        <Button Content="添加文件..." Click="AddFilesA_Click" Margin="0,0,8,0" />
                        <Button Content="移除选中" Click="RemoveSelectedA_Click" Margin="0,0,8,0" />
                        <Button Content="清空" Click="ClearA_Click" />
                    </StackPanel>
                    <ListBox x:Name="ListA" Margin="4" SelectionMode="Extended" DisplayMemberPath="FileName"
                             AllowDrop="True" PreviewDragOver="List_PreviewDragOver" Drop="ListA_Drop" />
                </DockPanel>
            </GroupBox>

                <!-- 汇总表模板 (bottom, small area) -->
                <GroupBox Header="汇总表模板" Grid.Row="1">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="4">
                            <Button Content="选择模板..." Click="AddFilesB_Click" Margin="0,0,8,0" />
                        <Button Content="移除选中" Click="RemoveSelectedB_Click" Margin="0,0,8,0" />
                        <Button Content="清空" Click="ClearB_Click" />
                    </StackPanel>
                        <ListBox x:Name="ListB" Margin="4" SelectionMode="Single" DisplayMemberPath="FileName"
                                 AllowDrop="True" PreviewDragOver="List_PreviewDragOver" Drop="ListB_Drop" MaxHeight="80" />
                </DockPanel>
            </GroupBox>
        </Grid>
        </Grid>

        <!-- Results area -->
        <GroupBox Header="Results" Grid.Row="1">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="Process" Click="Process_Click" Margin="0,0,8,0" />
                    <Button Content="Clear Results" Click="ClearResults_Click" />
                </StackPanel>

                    <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                        <Button Content="测试数据提取" Click="ProcessResults_Click" Margin="8,0,0,0" />
                        <Button Content="操作2" IsEnabled="False" Margin="8,0,0,0" />
                        <Button Content="操作3" IsEnabled="False" Margin="8,0,0,0" />
                        <Button Content="操作4" IsEnabled="False" Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
                <ListBox x:Name="ResultsList" Margin="4" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionMode="Extended"
                         PreviewKeyDown="ResultsList_PreviewKeyDown">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制 (Ctrl+C)" Click="ResultsList_CopyClick" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </GroupBox>
    </Grid>

</Window>
